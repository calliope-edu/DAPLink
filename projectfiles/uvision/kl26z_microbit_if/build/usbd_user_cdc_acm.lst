N
NUART_Configuration UART_Config;
N
N/** @brief  Vitual COM Port initialization
N *
N *  The function inititalizes the hardware resources of the port used as
N *  the Virtual COM Port.
N *
N *  @return 0 Function failed.
N *  @return 1 Function succeeded.
N */
Nint32_t USBD_CDC_ACM_PortInitialize(void)
N{
N    uart_initialize();
N    main_cdc_send_event();
N    return 1;
N}
N
N/** @brief  Vitual COM Port uninitialization
N *
N *  The function uninititalizes/releases the hardware resources of the port used
N *  as the Virtual COM Port.
N *
N *  @return 0 Function failed.
N *  @return 1 Function succeeded.
N */
Nint32_t USBD_CDC_ACM_PortUninitialize(void)
N{
N    uart_uninitialize();
N    return 1;
N}
N
N/** @brief  Vitual COM Port reset
N *
N *  The function resets the internal states of the port used
N *  as the Virtual COM Port.
N *
N *  @return 0 Function failed.
N *  @return 1 Function succeeded.
N */
Nint32_t USBD_CDC_ACM_PortReset(void)
N{
N    uart_reset();
N    return 1;
N}
N
N/** @brief  Virtual COM Port change communication settings
N *
N *  The function changes communication settings of the port used as the
N *  Virtual COM Port.
N *
N *  @param [in] line_coding Pointer to the loaded CDC_LINE_CODING structure.
N *  @return 0 Function failed.
N *  @return 1 Function succeeded.
N */
Nint32_t USBD_CDC_ACM_PortSetLineCoding(CDC_LINE_CODING *line_coding)
N{
N    UART_Config.Baudrate    = line_coding->dwDTERate;
N    UART_Config.DataBits    = (UART_DataBits) line_coding->bDataBits;
N    UART_Config.Parity      = (UART_Parity)   line_coding->bParityType;
N    UART_Config.StopBits    = (UART_StopBits) line_coding->bCharFormat;
N    UART_Config.FlowControl = UART_FLOW_CONTROL_NONE;
N    return uart_set_configuration(&UART_Config);
N}
N
N/** @brief  Vitual COM Port retrieve communication settings
N *
N * The function retrieves communication settings of the port used as the
N *  Virtual COM Port.
N *
N *  @param [in] line_coding Pointer to the CDC_LINE_CODING structure.
N *  @return 0 Function failed.
N *  @return 1 Function succeeded.
N */
Nint32_t USBD_CDC_ACM_PortGetLineCoding(CDC_LINE_CODING *line_coding)
N{
N    line_coding->dwDTERate   = UART_Config.Baudrate;
N    line_coding->bDataBits   = UART_Config.DataBits;
N    line_coding->bParityType = UART_Config.Parity;
N    line_coding->bCharFormat = UART_Config.StopBits;
N    return (1);
N}
N
Nstatic U32 start_break_time = 0;
Nint32_t USBD_CDC_ACM_SendBreak(uint16_t dur)
N{
N    uint32_t end_break_time;
N    if (!flash_intf_target->flash_busy()) { //added checking if flashing on target is in progress
N        // reset and send the unique id over CDC
N        if (dur != 0) {
N            start_break_time = os_time_get();
X            start_break_time = _os_time_get((U32)rt_time_get);
N            target_set_state(RESET_HOLD);
N        } else {
N            end_break_time = os_time_get();
X            end_break_time = _os_time_get((U32)rt_time_get);
N
N            // long reset -> send uID over serial (300 -> break > 3s)
N            if ((end_break_time - start_break_time) >= (300)) {
N                main_reset_target(1);
N            } else {
N                main_reset_target(0);
N            }
N        }
N    }
N    return (1);
N}
N
N/** @brief  Virtual COM Port set control line state
N *
N *  The function sets control line state on the port used as the
N *  Virtual COM Port.
N *
N *  @param [in] ctrl_bmp Control line settings
N *      bitmap (0. bit - DTR state, 1. bit - RTS state).
N *  @return 0 Function failed.
N *  @return 1 Function succeeded.
N */
Nint32_t USBD_CDC_ACM_PortSetControlLineState(uint16_t ctrl_bmp)
N{
N    return (1);
N}
N
Nvoid cdc_process_event()
N{
N    int32_t len_data = 0;
N    uint8_t data[64];
N
N    len_data = uart_read_data(data, sizeof(data));
N
N    if (len_data) {
N        selectr_read_command(data[0]);
N        USBD_CDC_ACM_DataSend(data , len_data);
N        main_blink_cdc_led(MAIN_LED_FLASH);
N    }
N
N
N    len_data = USBD_CDC_ACM_DataRead(data, sizeof(data));
N
N    if (len_data) {
N        uart_write_data(data, len_data);
N        main_blink_cdc_led(MAIN_LED_FLASH);
N    }
N 
N    // Always process events
N    main_cdc_send_event();
N}
