Nuint32_t read_flash_dir(uint32_t sector_offset, uint8_t *data, uint32_t num_sectors)
N{
N    uint32_t byte_offset = sector_offset * VFS_SECTOR_SIZE;
X    uint32_t byte_offset = sector_offset * 512;
N    uint32_t num_bytes = num_sectors * VFS_SECTOR_SIZE;
X    uint32_t num_bytes = num_sectors * 512;
N
N    vfs_nvm_read_DIR(data, byte_offset, num_bytes);
N
N	return num_bytes;
N}
N
Nvoid write_flash_dir(uint32_t sector_offset, const uint8_t *data, uint32_t num_sectors)
N{
N    FatDirectoryEntry_t old_entry;
N    FatDirectoryEntry_t new_entry;
N
N    uint32_t byte_offset = sector_offset * VFS_SECTOR_SIZE;
X    uint32_t byte_offset = sector_offset * 512;
N    uint32_t num_bytes = num_sectors * VFS_SECTOR_SIZE;
X    uint32_t num_bytes = num_sectors * 512;
N    uint32_t idx = 0u;
N
N    for (idx = 0u; idx < num_bytes; idx += sizeof(FatDirectoryEntry_t))
N    {
N        vfs_nvm_read_DIR((uint8_t*)(&old_entry), byte_offset + idx, sizeof(FatDirectoryEntry_t));
N
N        if (memcmp(&old_entry, &data[idx], sizeof(FatDirectoryEntry_t)) != 0u)
N        {
N            if (vfs_strncmp(&data[idx], "SELECTR HEX") == 0u)
N            {
N                memcpy(&new_entry, &data[idx], sizeof(FatDirectoryEntry_t));
N                new_entry.attributes = VFS_FILE_ATTR_READ_ONLY
N                                     | VFS_FILE_ATTR_HIDDEN
N                                     | VFS_FILE_ATTR_SYSTEM
N                                     | VFS_FILE_ATTR_ARCHIVE;
N
N                vfs_nvm_write_DIR((uint8_t*)(&new_entry), byte_offset + idx, sizeof(FatDirectoryEntry_t));
N            }
N            else
N            {
N                vfs_nvm_write_DIR(&data[idx], byte_offset + idx, sizeof(FatDirectoryEntry_t));
N            }
N        }
N        else
N        {
N            /* */
N        }
N    }
N}
N
Nuint32_t read_flash_file(uint32_t sector_offset, uint8_t *data, uint32_t num_sectors)
