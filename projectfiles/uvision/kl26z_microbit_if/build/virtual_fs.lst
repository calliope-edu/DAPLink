Nuint8_t vfs_get_flash_names_srtd(vfs_filename_t* filename, uint8_t max_count)
N{
N    uint16_t addr = 0u;
N    uint8_t filenames_found = 0u;
N    FatDirectoryEntry_t de;
N
N    for (addr = 0u; addr < VFS_NVM_DIR_SIZE; addr+=sizeof(FatDirectoryEntry_t))
X    for (addr = 0u; addr < (0x1000-0x000000u); addr+=sizeof(FatDirectoryEntry_t))
N    {
N        vfs_nvm_read_DIR((uint8_t*)(&de), addr, sizeof(FatDirectoryEntry_t));
N
N        if (filename_valid(de.filename) != 0u)
N        {
N            if ((vfs_strncmp((de.filename), "SELECTR HEX")!=0) && ((de.attributes & VFS_FILE_ATTR_HIDDEN) == 0u))
N            {
N                if (strncmp("HEX", (const char *)(&(de.filename[8])), 3) == 0)
N                {
N                    if (filenames_found < max_count)
N                    {
N                        memcpy(&(filename[filenames_found]), &(de.filename), sizeof(vfs_filename_t));
N                        filenames_found++;
N                    }
N                    else
N                    {
N                        // filename buffer full
N                        // terminate the for loop
N                        addr = VFS_NVM_DIR_SIZE;
X                        addr = (0x1000-0x000000u);
N                    }
N                }
N                else
N                {
N                    // skip non-HEX files
N                }
N            }
N            else
N            {
N                // skip the "selector" file and hidden files
N            }
N        }
N        else
N        {
N            // filename invalid, not a file?
N        }
N    }
N
N    qsort(filename, filenames_found, sizeof(vfs_filename_t), vfs_strncmp);
N
N    return filenames_found;
N}
N
Nuint8_t vfs_find_flash_file(vfs_filename_t filename, uint16_t * const first_cluster, uint32_t * const filesize)
N{
N    uint16_t addr = 0u;
N    uint8_t result = 0u;
N    FatDirectoryEntry_t de;
N
N    *first_cluster = 0xFFFFu;
N    *filesize = 0u;
N
N    if (filename_valid(filename)!=0u)
N    {
N        for (addr = 0u; addr < VFS_NVM_DIR_SIZE; addr+=sizeof(FatDirectoryEntry_t))
X        for (addr = 0u; addr < (0x1000-0x000000u); addr+=sizeof(FatDirectoryEntry_t))
N        {
N            vfs_nvm_read_DIR((uint8_t*)(&de), addr, sizeof(FatDirectoryEntry_t));
N
N            if (vfs_strncmp(de.filename, filename) == 0u)
N            {
N                // filename is matching, finalize
N                *first_cluster = de.first_cluster_low_16;
N                *filesize = de.filesize;
N
N                // terminate the for loop
N                addr = VFS_NVM_DIR_SIZE;
X                addr = (0x1000-0x000000u);
N
N                result = 1u;
N            }
N            else
N            {
N                // filename is not matching, continue searching
N                result = 0u;
N            }
N        }
N    }
N    else
N    {
N        // filename is invalid, skip
N        result = 0u;
N    }
N
N    return result;
N}
