X    uint32_t byte_offset = sector_offset * 512;
N    uint32_t num_bytes = num_sectors * VFS_SECTOR_SIZE;
X    uint32_t num_bytes = num_sectors * 512;
N
N    vfs_nvm_write_FILE(data, byte_offset, num_bytes);
N}
