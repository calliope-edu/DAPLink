N
N#define SELECTR_BUF_SIZE 256u
N#define VFS_NVM_FILE_CNT_MAX 25u        // max number of HEX files allowed in the FLASH chip (25 programs)
N
Nstatic uint8_t selector_mode = 0u;
Nstatic uint8_t file_idx = 0u;
Nstatic uint8_t filenames_found = 0u;
Nstatic vfs_filename_t filenames[VFS_NVM_FILE_CNT_MAX];
Xstatic vfs_filename_t filenames[25u];
N
Nstatic uint16_t cluster_count = 0u;
Nstatic uint32_t file_size = 0u;
Nstatic uint16_t cluster = 0u;
N
Nstatic uint16_t cluster_counter = 0u;
Nstatic uint32_t program_size = 0u;
Nstatic uint32_t page_address = 0u;
Nstatic uint32_t sector_address = 0u;
Nstatic uint8_t program_buf[SELECTR_BUF_SIZE];
Xstatic uint8_t program_buf[256u];
Nstatic uint8_t program_flag = 0u;
N
Nuint8_t selectr_start_mode(void)
N{
N    uint8_t result = 0u;
N
N    // Program target micro with "selector" software
N    if (selectr_program_start("SELECTR HEX") != 0u)
N    {
N        file_idx = 0u;
N        filenames_found = 0u;
N        selector_mode = 1u;
N        memset(filenames, 0, VFS_NVM_FILE_CNT_MAX*(sizeof(vfs_filename_t)));
X        memset(filenames, 0, 25u*(sizeof(vfs_filename_t)));
N
N        result = 1u;
N    }
N    else
N    {
N        result = 0u;
N    }
N
N    return result;
N}
N
Nvoid selectr_read_command(char command)
N{
N    if (selector_mode != 0u)
N    {
N        if (command == 'R')
N        {
N            // Target micro loaded with "selector" software and ready for operation
N            filenames_found = vfs_get_flash_names_srtd(filenames, VFS_NVM_FILE_CNT_MAX);
X            filenames_found = vfs_get_flash_names_srtd(filenames, 25u);
N
N            if (filenames_found > 0u)
N            {
N                file_idx = 1u; // select first program file by default
N                selectr_write_command(file_idx);
N            }
N            else
N            {
N                selectr_write_command(13u); // FLASH dir is empty, blink central LED
N            }
N        }
N        else if (command == 'A')
N        {
N            // Button A pressed
N            if (file_idx > 1u)
N            {
N                file_idx --;
N                selectr_write_command(file_idx);
N            }
N            else
N            {
N                if (filenames_found > 0u)
N                {
N                    file_idx = filenames_found;
N                    selectr_write_command(file_idx);
N                }
N                else
N                {
N                    selectr_write_command(13u); // FLASH dir is empty, blink central LED
N                }
N            }
N        }
N        else if (command == 'B')
N        {
N            // Button B pressed
N            if ( file_idx < filenames_found )
N            {
N                file_idx ++;
N                selectr_write_command(file_idx);
N            }
N            else
N            {
N                if (filenames_found > 0u)
N                {
N                    file_idx = 1u;
N                    selectr_write_command(file_idx);
N                }
N                else
N                {
N                    selectr_write_command(13u); // FLASH dir is empty, blink central LED
N                }
N            }
N        }
N        else if ((command == 'C') || (command == 'S'))
N        {
N            // Buttons A+B pressed OR Shake detected
N            if (file_idx != 0u)
N            {
N                selector_mode = 0u;
N
N                if (selectr_program_start(filenames[file_idx-1u]) != 0u)
N                {
N
N                }
N                else
N                {
N                    selectr_write_command(13u); // FLASH dir is empty, blink central LED
N                }
N            }
N            else
N            {
N                selectr_write_command(13u); // FLASH dir is empty, blink central LED
N            }
N        }
N        else
N        {
N            // ignore
N        }
N    }
N    else
N    {
N        // ignore
N    }
N}
N
Nvoid selectr_write_command(char command)
N{
N    uint8_t data[3] = {(uint8_t)command, 0x0Du, 0x0Au};
N    util_write_uint32((char*)(&(data[0])), (uint8_t)command);
N    uart_write_data(data, 3u);
N}
N
Nuint8_t selectr_program_start(vfs_filename_t filename)
N{
N    uint8_t result = 0u;
N
N    stream_type_t stream_type = STREAM_TYPE_NONE;
N
N    stream_type = stream_type_from_name(filename);
N
N    if (stream_type != STREAM_TYPE_NONE)
N    {
N        if (vfs_find_flash_file(filename, &cluster, &file_size) != 0u)
N        {
N            stream_open(stream_type);
N
N            cluster_count = (file_size + VFS_CLUSTER_SIZE - 1u) / VFS_CLUSTER_SIZE;
X            cluster_count = (file_size + 0x1000 - 1u) / 0x1000;
N            cluster_counter = 0u;
N            program_size = 0u;
N            page_address = 0u;
N            sector_address = ((cluster - 2u) * VFS_CLUSTER_SIZE);
X            sector_address = ((cluster - 2u) * 0x1000);
N
N            program_flag = 1u;
N
N            result = 1u;
N        }
N        else
N        {
N            result = 0u;
N        }
N    }
N    else
N    {
N        result = 0u;
N    }
N
N    return result;
N}
N
Nuint8_t selectr_program_handler(void)
N{
N    uint8_t result = 0u;
N
N    if (program_flag != 0u)
N    {
N        //for (cluster_cnt = 0u; cluster_cnt < cluster_count; cluster_cnt++)
N        if (cluster_counter < cluster_count)
N        {
N            if (cluster >= 0xFFF0u)
N            {
N                //end of chain, last cluster in file, bad sector, reserved...
N                //terminate the loop
N                cluster_counter = cluster_count;
N            }
N            else if (cluster >= 0x0002u)
N            {
N                main_blink_hid_led(MAIN_LED_FLASH);
N                //data cluster, use it to read next part of the file
N
N                if (page_address < VFS_CLUSTER_SIZE)
X                if (page_address < 0x1000)
N                {
N                    if (program_size + SELECTR_BUF_SIZE < file_size)
X                    if (program_size + 256u < file_size)
N                    {
N                        vfs_nvm_read_FILE(program_buf, sector_address + page_address, SELECTR_BUF_SIZE);
X                        vfs_nvm_read_FILE(program_buf, sector_address + page_address, 256u);
N                        stream_write(program_buf, SELECTR_BUF_SIZE);
X                        stream_write(program_buf, 256u);
N                        program_size += SELECTR_BUF_SIZE;
X                        program_size += 256u;
N                        page_address += SELECTR_BUF_SIZE;
X                        page_address += 256u;
N                    }
N                    else
N                    {
N                        vfs_nvm_read_FILE(program_buf, sector_address + page_address, (file_size-program_size));
N                        stream_write(program_buf, (file_size-program_size));
N                        program_size += (file_size-program_size);
N                        page_address += (file_size-program_size);
N
N                        //filesize reached, stop further reading/streaming
N                        //terminate the loop
N                        cluster_counter = cluster_count;
N                        page_address = 0u;
N                    }
N                }
N                else
N                {
N                    //read next cluster number
N                    vfs_nvm_read_FAT(program_buf, (cluster * 2u), 2u);
N
N                    cluster = program_buf[1];
N                    cluster <<= 8u;
N                    cluster |= program_buf[0];
N
N                    sector_address = ((cluster - 2u) * VFS_CLUSTER_SIZE);
X                    sector_address = ((cluster - 2u) * 0x1000);
N
N                    cluster_counter++;
N                    page_address = 0u;
N                }
N            }
N            else
N            {
N                //invalid, reserved cluster
N                //terminate the loop
N                cluster_counter = cluster_count;
N            }
N
N            result = 1u;
N
N        }
N        else if (cluster_counter == cluster_count)
N        {
N            stream_close();
N
N            program_flag = 0u;
N
N            //run this block once
N            cluster_counter++;
N
N            uart_reset();
N
N            result = 0u;
N        }
N        else
N        {
N            result = 0u;
N        }
N    }
N    else
N    {
N        result = 0u;
N    }
N
N    return result;
N}
