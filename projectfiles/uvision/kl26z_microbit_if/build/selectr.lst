N/**
N * @file    vfs_nvm.h
N * @brief   FAT 12/16 filesystem non-volatile memory management
N */
N
N#ifndef VFS_NVM_H
N#define VFS_NVM_H
N
N#include "stdint.h"
N#include "stdbool.h"
N
N#ifdef __cplusplus
Sextern "C" {
N#endif
N
N
N/* NVM MEMORY LAYOUT
N * START ADDR   -   NAME           - SIZE
N * 0x00000000   -   DIR REGION     - 0x00001000
N * 0x00001000   -   DATA REGION    - 0x00FCF000
N * 0x00FD0000   -   FAT REGION     - 0x00020000
N * 0X00FF0000   -   REWRITE BUFFER - 0X00010000
N */
N
N#define VFS_NVM_FAT_ADDR 0xFEC000u                              // starting address for FAT table in the FLASH directory
N#define VFS_NVM_FAT_SIZE 16384u                                 // maximum size for maximum number of 65425 clusters allowed
N
N#define VFS_NVM_FILE_ADDR 0x1000                                // starting address for storage of files in FLASH directory
N#define VFS_NVM_FILE_SIZE (VFS_NVM_FAT_ADDR-VFS_NVM_FILE_ADDR)  // size for files in a FLASH directory
N
N#define VFS_NVM_DIR_ADDR 0x000000u                              // starting address for FLASH directory entry
N#define VFS_NVM_DIR_SIZE (VFS_NVM_FILE_ADDR-VFS_NVM_DIR_ADDR)   // size for 128 FatDirectoryEntries (32 bytes each)
N
N
Nvoid vfs_nvm_init(void);
N
Nuint8_t vfs_nvm_is_available(void);
N
Nvoid vfs_nvm_read_FAT(uint8_t *buf, uint32_t offset, uint32_t len);
N
Nvoid vfs_nvm_write_FAT(const uint8_t *buf, uint32_t offset, uint32_t len);
N
Nvoid vfs_nvm_setup_FAT(void);
N
Nvoid vfs_nvm_read_DIR(uint8_t *buf, uint32_t offset, uint32_t len);
N
Nvoid vfs_nvm_write_DIR(const uint8_t *buf, uint32_t offset, uint32_t len);
N
Nvoid vfs_nvm_setup_DIR(void);
N
Nvoid vfs_nvm_read_FILE(uint8_t *buf, uint32_t offset, uint32_t len);
N
Nvoid vfs_nvm_write_FILE(const uint8_t *buf, uint32_t offset, uint32_t len);
N
N#ifdef __cplusplus
S}
N#endif
N
N#endif //VFS_NVM_H
