N#define ELEMENTS_IN_ARRAY(array)        (sizeof(array)/sizeof(array[0]))
N
N#define MB(size)                        ((size) * 1024 * 1024)
N
N#define KB(size)                        ((size) * 1024)
N
N#define MIN(a,b)                        ((a) < (b) ? (a) : (b))
N
N#define MAX(a,b)                        ((a) > (b) ? (a) : (b))
