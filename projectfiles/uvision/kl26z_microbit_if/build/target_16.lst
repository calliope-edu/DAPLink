N#include "flash_blob.h"
N
Nstatic const uint32_t nRF51822AA_FLM[] = {
N    0xE00ABE00, 0x062D780D, 0x24084068, 0xD3000040, 0x1E644058, 0x1C49D1FA, 0x2A001E52, 0x4770D1F2,
N
N    /*0x020*/ 0x47702000, 0x47702000, 0x4c26b570, 0x60602002, 0x60e02001, 0x68284d24, 0xd00207c0L, 0x60602000,
N    /*0x040*/ 0xf000bd70L, 0xe7f6f82cL, 0x4c1eb570, 0x60612102, 0x4288491e, 0x2001d302, 0xe0006160L, 0x4d1a60a0,
N    /*0x060*/ 0xf81df000L, 0x7c06828, 0x2000d0fa, 0xbd706060L, 0x4605b5f8, 0x4813088e, 0x46142101, 0x4f126041,
N    /*0x080*/ 0xc501cc01L, 0x7c06838, 0x1e76d006, 0x480dd1f8, 0x60412100, 0xbdf84608L, 0xf801f000L, 0x480ce7f2,
N    /*0x0A0*/ 0x6006840, 0xd00b0e00L, 0x6849490a, 0xd0072900L, 0x4a0a4909, 0xd00007c3L, 0x1d09600a, 0xd1f90840L,
N    /*0x0C0*/ 0x4770, 0x4001e500, 0x4001e400, 0x10001000, 0x40010400, 0x40010500, 0x40010600, 0x6e524635,
N    /*0x0E0*/ 0x0,
N};
N
Nstatic const program_target_t flash = {
N    .init = 0x20000021,
N    .uninit = 0x20000025,
N    .erase_chip = 0x20000029,
N    .erase_sector = 0x20000049,
N    .program_page = 0x20000071,
N    .verify = 0x0,
N    {
N        .breakpoint = 0x20000001,
N        .static_base = 0x20000020 + 0x00000150,
N        .stack_pointer = 0x20001000
N    },
N    .program_buffer = 0x20000200,
N    .algo_start = 0x20000000,
N    .algo_size = 0x00000150,
N    .algo_blob = nRF51822AA_FLM,
N    .program_buffer_size = 512 // should be USBD_MSC_BlockSize
N};
L 26 "..\..\..\source\target\nordic\nrf51822\target_16.c" 2
N
N// target information
Ntarget_cfg_t target_device = {
N    .sector_size    = 1024,
N    .sector_cnt     = (KB(256) / 1024),
X    .sector_cnt     = (((256) * 1024) / 1024),
N    .flash_start    = 0,
N    .flash_end      = KB(256),
X    .flash_end      = ((256) * 1024),
N    .ram_start      = 0x20000000,
N    .ram_end        = 0x20004000,
N    .flash_algo     = (program_target_t *) &flash,
N    .erase_reset    = 1,
N};
