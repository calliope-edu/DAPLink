N
N#ifdef __cplusplus
Sextern "C" {
N#endif
N
Ntypedef int cortex_int_state_t;
N
N__attribute__((always_inline))
Nstatic cortex_int_state_t cortex_int_get_and_disable(void)
N{
N    cortex_int_state_t state;
N    state = __disable_irq();
N    return state;
N}
N
N__attribute__((always_inline))
Nstatic void cortex_int_restore(cortex_int_state_t state)
N{
N    if (!state) {
N        __enable_irq();
N    }
N}
N
N__attribute__((always_inline))
Nstatic bool cortex_in_isr(void)
Xstatic _Bool cortex_in_isr(void)
N{
N    return (__get_xPSR() & 0x1F) != 0;
N}
N
Nextern void SystemReset(void);
N
N#ifdef __cplusplus
S}
N#endif
N
N#endif
L 26 "..\..\..\source\daplink\HardFault_Handler.c" 2
N
Nregister unsigned int _psp __asm("psp");
Nregister unsigned int _msp __asm("msp");
Nregister unsigned int _lr __asm("lr");
Nregister unsigned int _control __asm("control");
Nvoid HardFault_Handler()
N{
N//hexdump logic on hardfault
N    uint32_t stk_ptr;
N    uint32_t * stack = (uint32_t *)_msp;
N    
N    if ((_lr & 0xF) == 0xD) { //process stack
N        stack = (uint32_t *)_psp;
N    }
N
N    //calculate stack ptr before fault
N    stk_ptr = (uint32_t)stack + 0x20;
N    if ((stack[7] & 0x200) != 0) { //xpsr bit 9 align
N        stk_ptr += 0x4;
N    }
N    if ((_lr & 0x10) == 0) { //fp
N        stk_ptr += 0x48;
N    }
N    
N    config_ram_add_hexdump(_lr);  //EXC_RETURN
N    config_ram_add_hexdump(_psp);
N    config_ram_add_hexdump(_msp);
N    config_ram_add_hexdump(_control);
N    config_ram_add_hexdump(stk_ptr); //SP
N    config_ram_add_hexdump(stack[5]);  //LR
N    config_ram_add_hexdump(stack[6]);  //PC
N    config_ram_add_hexdump(stack[7]);  //xPSR 
N
N#ifndef __CORTEX_M
S#error __CORTEX_M not defined!!
N#else
N
N#if (__CORTEX_M > 0x00)
X#if ((0x00) > 0x00)
S    config_ram_add_hexdump(SCB->HFSR);
S    config_ram_add_hexdump(SCB->CFSR);
S    config_ram_add_hexdump(SCB->DFSR);
S    config_ram_add_hexdump(SCB->AFSR);
S    config_ram_add_hexdump(SCB->MMFAR);
S    config_ram_add_hexdump(SCB->BFAR);
N#endif  
N
N#endif //#ifndef __CORTEX_M
N
N    //util_assert(0);
N    SystemReset();
N
N    while (1); // Wait for reset
N}
