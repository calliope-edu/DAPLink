N**     mail:                 support@freescale.com
N**
N**     Revisions:
N**     - rev. 1.0 (2012-12-12)
N**         Initial version.
N**     - rev. 1.1 (2013-04-05)
N**         Changed start of doxygen comment.
N**     - rev. 1.2 (2013-04-12)
N**         SystemInit function fixed for clock configuration 1.
N**         Name of the interrupt num. 31 updated to reflect proper function.
N**     - rev. 1.3 (2014-05-27)
N**         Updated to Kinetis SDK support standard.
N**         MCG OSC clock select supported (MCG_C7[OSCSEL]).
N**     - rev. 1.4 (2014-07-25)
N**         System initialization updated:
N**         - Prefix added to the system initialization parameterization constants to avoid name conflicts..
N**         - VLLSx wake-up recovery added.
N**         - Delay of 1 ms added to SystemInit() to ensure stable FLL output in FEI and FEE MCG modes.
N**     - rev. 1.5 (2014-08-28)
N**         Update of system files - default clock configuration changed, fix of OSC initialization.
N**         Update of startup files - possibility to override DefaultISR added.
N**     - rev. 1.6 (2014-10-14)
N**         Renamed interrupt vector LPTimer to LPTMR0
N**     - rev. 1.7 (2015-02-18)
N**         Renamed interrupt vector LLW to LLWU
N**     - rev. 1.8 (2015-07-29)
N**         Correction of backward compatibility.
N**
N** ###################################################################
N*/
N
N/*!
N * @file MKL26Z4.h
N * @version 1.8
N * @date 2015-07-29
N * @brief CMSIS Peripheral Access Layer for MKL26Z4
N *
N * CMSIS Peripheral Access Layer for MKL26Z4
N */
N
N#ifndef _MKL26Z4_H_
N#define _MKL26Z4_H_                              /**< Symbol preventing repeated inclusion */
N
N/** Memory map major version (memory maps with equal major version number are
N * compatible) */
N#define MCU_MEM_MAP_VERSION 0x0100U
N/** Memory map minor version */
N#define MCU_MEM_MAP_VERSION_MINOR 0x0008U
N
N
N/* ----------------------------------------------------------------------------
N   -- Interrupt vector numbers
N   ---------------------------------------------------------------------------- */
N
N/*!
N * @addtogroup Interrupt_vector_numbers Interrupt vector numbers
N * @{
N */
N
N/** Interrupt Number Definitions */
N#define NUMBER_OF_INT_VECTORS 48                 /**< Number of interrupts in the Vector table */
N
Ntypedef enum IRQn {
N  /* Auxiliary constants */
N  NotAvail_IRQn                = -128,             /**< Not available device specific interrupt */
N
N  /* Core interrupts */
N  NonMaskableInt_IRQn          = -14,              /**< Non Maskable Interrupt */
N  HardFault_IRQn               = -13,              /**< Cortex-M0 SV Hard Fault Interrupt */
N  SVCall_IRQn                  = -5,               /**< Cortex-M0 SV Call Interrupt */
N  PendSV_IRQn                  = -2,               /**< Cortex-M0 Pend SV Interrupt */
N  SysTick_IRQn                 = -1,               /**< Cortex-M0 System Tick Interrupt */
N
N  /* Device specific interrupts */
N  DMA0_IRQn                    = 0,                /**< DMA channel 0 transfer complete and error interrupt */
N  DMA1_IRQn                    = 1,                /**< DMA channel 1 transfer complete and error interrupt */
N  DMA2_IRQn                    = 2,                /**< DMA channel 2 transfer complete and error interrupt */
N  DMA3_IRQn                    = 3,                /**< DMA channel 3 transfer complete and error interrupt */
N  Reserved20_IRQn              = 4,                /**< Reserved interrupt */
N  FTFA_IRQn                    = 5,                /**< FTFA command complete and read collision */
N  LVD_LVW_IRQn                 = 6,                /**< Low-voltage detect, low-voltage warning */
N  LLWU_IRQn                    = 7,                /**< Low Leakage Wakeup */
N  I2C0_IRQn                    = 8,                /**< I2C0 interrupt */
N  I2C1_IRQn                    = 9,                /**< I2C1 interrupt */
N  SPI0_IRQn                    = 10,               /**< SPI0 single interrupt vector for all sources */
N  SPI1_IRQn                    = 11,               /**< SPI1 single interrupt vector for all sources */
N  UART0_IRQn                   = 12,               /**< UART0 status and error */
N  UART1_IRQn                   = 13,               /**< UART1 status and error */
N  UART2_IRQn                   = 14,               /**< UART2 status and error */
N  ADC0_IRQn                    = 15,               /**< ADC0 interrupt */
N  CMP0_IRQn                    = 16,               /**< CMP0 interrupt */
N  TPM0_IRQn                    = 17,               /**< TPM0 single interrupt vector for all sources */
N  TPM1_IRQn                    = 18,               /**< TPM1 single interrupt vector for all sources */
N  TPM2_IRQn                    = 19,               /**< TPM2 single interrupt vector for all sources */
N  RTC_IRQn                     = 20,               /**< RTC alarm interrupt */
N  RTC_Seconds_IRQn             = 21,               /**< RTC seconds interrupt */
N  PIT_IRQn                     = 22,               /**< PIT single interrupt vector for all channels */
N  I2S0_IRQn                    = 23,               /**< I2S0 Single interrupt vector for all sources */
N  USB0_IRQn                    = 24,               /**< USB0 OTG */
N  DAC0_IRQn                    = 25,               /**< DAC0 interrupt */
N  TSI0_IRQn                    = 26,               /**< TSI0 interrupt */
N  MCG_IRQn                     = 27,               /**< MCG interrupt */
N  LPTMR0_IRQn                  = 28,               /**< LPTMR0 interrupt */
N  Reserved45_IRQn              = 29,               /**< Reserved interrupt */
N  PORTA_IRQn                   = 30,               /**< PORTA pin detect */
N  PORTC_PORTD_IRQn             = 31                /**< Single interrupt vector for PORTC and PORTD pin detect */
N} IRQn_Type;
N
N/*!
N * @}
N */ /* end of group Interrupt_vector_numbers */
N
