N/** Mapping Information */
N/*!
N * @addtogroup edma_request
N * @{
N */
N
N/*******************************************************************************
N * Definitions
N ******************************************************************************/
N
N/*!
N * @brief Structure for the DMA hardware request
N *
N * Defines the structure for the DMA hardware request collections. The user can configure the
N * hardware request into DMAMUX to trigger the DMA transfer accordingly. The index
N * of the hardware request varies according  to the to SoC.
N */
Ntypedef enum _dma_request_source
N{
N    kDmaRequestMux0Disable          = 0|0x100U,    /**< Disable */
N    kDmaRequestMux0Reserved1        = 1|0x100U,    /**< Reserved1 */
N    kDmaRequestMux0UART0Rx          = 2|0x100U,    /**< UART0 receive complete */
N    kDmaRequestMux0LPSCI0Rx         = 2|0x100U,    /**< UART0 receive complete */
N    kDmaRequestMux0UART0Tx          = 3|0x100U,    /**< UART0 transmit complete */
N    kDmaRequestMux0LPSCI0Tx         = 3|0x100U,    /**< UART0 transmit complete */
N    kDmaRequestMux0UART1Rx          = 4|0x100U,    /**< UART1 receive complete */
N    kDmaRequestMux0UART1Tx          = 5|0x100U,    /**< UART1 transmit complete */
N    kDmaRequestMux0UART2Rx          = 6|0x100U,    /**< UART2 receive complete */
N    kDmaRequestMux0UART2Tx          = 7|0x100U,    /**< UART2 transmit complete */
N    kDmaRequestMux0Reserved8        = 8|0x100U,    /**< Reserved8 */
N    kDmaRequestMux0Reserved9        = 9|0x100U,    /**< Reserved9 */
N    kDmaRequestMux0Reserved10       = 10|0x100U,   /**< Reserved10 */
N    kDmaRequestMux0Reserved11       = 11|0x100U,   /**< Reserved11 */
N    kDmaRequestMux0Reserved12       = 12|0x100U,   /**< Reserved12 */
N    kDmaRequestMux0Reserved13       = 13|0x100U,   /**< Reserved13 */
N    kDmaRequestMux0I2S0Rx           = 14|0x100U,   /**< I2S0 receive complete */
N    kDmaRequestMux0I2S0Tx           = 15|0x100U,   /**< I2S0 transmit complete */
N    kDmaRequestMux0SPI0Rx           = 16|0x100U,   /**< SPI0 receive complete */
N    kDmaRequestMux0SPI0Tx           = 17|0x100U,   /**< SPI0 transmit complete */
N    kDmaRequestMux0SPI1Rx           = 18|0x100U,   /**< SPI1 receive complete */
N    kDmaRequestMux0SPI1Tx           = 19|0x100U,   /**< SPI1 transmit complete */
N    kDmaRequestMux0Reserved20       = 20|0x100U,   /**< Reserved20 */
N    kDmaRequestMux0Reserved21       = 21|0x100U,   /**< Reserved21 */
N    kDmaRequestMux0I2C0             = 22|0x100U,   /**< I2C0 transmission complete */
N    kDmaRequestMux0I2C1             = 23|0x100U,   /**< I2C1 transmission complete */
N    kDmaRequestMux0TPM0Channel0     = 24|0x100U,   /**< TPM0 channel 0 event (CMP or CAP) */
N    kDmaRequestMux0TPM0Channel1     = 25|0x100U,   /**< TPM0 channel 1 event (CMP or CAP) */
N    kDmaRequestMux0TPM0Channel2     = 26|0x100U,   /**< TPM0 channel 2 event (CMP or CAP) */
N    kDmaRequestMux0TPM0Channel3     = 27|0x100U,   /**< TPM0 channel 3 event (CMP or CAP) */
N    kDmaRequestMux0TPM0Channel4     = 28|0x100U,   /**< TPM0 channel 4 event (CMP or CAP) */
N    kDmaRequestMux0TPM0Channel5     = 29|0x100U,   /**< TPM0 channel 5 event (CMP or CAP) */
N    kDmaRequestMux0Reserved30       = 30|0x100U,   /**< Reserved30 */
N    kDmaRequestMux0Reserved31       = 31|0x100U,   /**< Reserved31 */
N    kDmaRequestMux0TPM1Channel0     = 32|0x100U,   /**< TPM1 channel 0 event (CMP or CAP) */
N    kDmaRequestMux0TPM1Channel1     = 33|0x100U,   /**< TPM1 channel 1 event (CMP or CAP) */
N    kDmaRequestMux0TPM2Channel0     = 34|0x100U,   /**< TPM2 channel 0 event (CMP or CAP) */
N    kDmaRequestMux0TPM2Channel1     = 35|0x100U,   /**< TPM2 channel 1 event (CMP or CAP) */
N    kDmaRequestMux0Reserved36       = 36|0x100U,   /**< Reserved36 */
N    kDmaRequestMux0Reserved37       = 37|0x100U,   /**< Reserved37 */
N    kDmaRequestMux0Reserved38       = 38|0x100U,   /**< Reserved38 */
N    kDmaRequestMux0Reserved39       = 39|0x100U,   /**< Reserved39 */
N    kDmaRequestMux0ADC0             = 40|0x100U,   /**< ADC0 conversion complete */
N    kDmaRequestMux0Reserved41       = 41|0x100U,   /**< Reserved41 */
N    kDmaRequestMux0CMP0             = 42|0x100U,   /**< CMP0 Output */
N    kDmaRequestMux0Reserved43       = 43|0x100U,   /**< Reserved43 */
N    kDmaRequestMux0Reserved44       = 44|0x100U,   /**< Reserved44 */
N    kDmaRequestMux0DAC0             = 45|0x100U,   /**< DAC0 buffer pointer reaches upper or lower limit */
N    kDmaRequestMux0Reserved46       = 46|0x100U,   /**< Reserved46 */
N    kDmaRequestMux0Reserved47       = 47|0x100U,   /**< Reserved47 */
N    kDmaRequestMux0Reserved48       = 48|0x100U,   /**< Reserved48 */
N    kDmaRequestMux0PortA            = 49|0x100U,   /**< PORTA rising, falling or both edges */
N    kDmaRequestMux0Reserved50       = 50|0x100U,   /**< Reserved50 */
N    kDmaRequestMux0PortC            = 51|0x100U,   /**< PORTC rising, falling or both edges */
N    kDmaRequestMux0PortD            = 52|0x100U,   /**< PORTD rising, falling or both edges */
N    kDmaRequestMux0Reserved53       = 53|0x100U,   /**< Reserved53 */
N    kDmaRequestMux0TPM0Overflow     = 54|0x100U,   /**< TPM0 overflow */
N    kDmaRequestMux0TPM1Overflow     = 55|0x100U,   /**< TPM1 overflow */
N    kDmaRequestMux0TPM2Overflow     = 56|0x100U,   /**< TPM2 overflow */
N    kDmaRequestMux0TSI              = 57|0x100U,   /**< TSI0 event */
N    kDmaRequestMux0Reserved58       = 58|0x100U,   /**< Reserved58 */
N    kDmaRequestMux0Reserved59       = 59|0x100U,   /**< Reserved59 */
N    kDmaRequestMux0AlwaysOn60       = 60|0x100U,   /**< Always enabled 60 */
N    kDmaRequestMux0AlwaysOn61       = 61|0x100U,   /**< Always enabled 61 */
N    kDmaRequestMux0AlwaysOn62       = 62|0x100U,   /**< Always enabled 62 */
N    kDmaRequestMux0AlwaysOn63       = 63|0x100U,   /**< Always enabled 63 */
N} dma_request_source_t;
N
N/* @} */
N
N
N/*!
N * @}
N */ /* end of group Mapping_Information */
