X    uint32_t app_end = 0x00008000 + 0x00017C00;
N
N    // Check if the sector is part of the application
N    if ((addr >= app_start) && (addr < app_end)) {
N        return false;
X        return 0;
N    }
N
N    return true;
X    return 1;
N}
