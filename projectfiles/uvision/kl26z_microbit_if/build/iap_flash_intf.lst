Nstatic error_t intercept_page_write(uint32_t addr, const uint8_t *buf, uint32_t size)
N{
N    error_t status;
N    uint32_t crc_size;
N    uint32_t updt_start = DAPLINK_ROM_UPDATE_START;
X    uint32_t updt_start = 0x00000000;
N    uint32_t updt_end = DAPLINK_ROM_UPDATE_START + DAPLINK_ROM_UPDATE_SIZE;
X    uint32_t updt_end = 0x00000000 + 0x00007C00;
N
N    if (state != STATE_OPEN) {
N        util_assert(0);
X        _util_assert((0), "..\\..\\..\\source\\daplink\\drag-n-drop\\iap_flash_intf.c", 378);
N        return ERROR_INTERNAL;
N    }
N
N    if ((addr < updt_start) || (addr >= updt_end)) {
N        return ERROR_IAP_OUT_OF_BOUNDS;
N    }
N
N    if (!daplink_is_interface()) {
N        return ERROR_IAP_NO_INTERCEPT;
N    }
N
N    /* Everything below here is interface specific */
N    crc_size = MIN(size, updt_end - addr - 4);
X    crc_size = ((size) < (updt_end - addr - 4) ? (size) : (updt_end - addr - 4));
N    crc = crc32_continue(crc, buf, crc_size);
N
N    // Intercept the data if it is in the first sector
N    if ((addr >= updt_start) && (addr < updt_start + DAPLINK_SECTOR_SIZE)) {
X    if ((addr >= updt_start) && (addr < updt_start + 0x00000400)) {
N        uint32_t buf_offset = addr - updt_start;
N        memcpy(sector_buf + buf_offset, buf, size);
N        // Intercept was successful
N        return ERROR_SUCCESS;
N    }
N
N    // Finalize update if this is the last sector
N    if (updt_end == addr + size) {
N        uint32_t iap_status;
N        uint32_t size_left = updt_end - addr;
N        uint32_t crc_in_image = (buf[size_left - 4] << 0) |
N                                (buf[size_left - 3] << 8) |
N                                (buf[size_left - 2] << 16) |
N                                (buf[size_left - 1] << 24);
N
N        if (crc != crc_in_image) {
N            return ERROR_BL_UPDT_BAD_CRC;
N        }
N
N        // Program the current buffer
N        iap_status = flash_program_page(addr, size, (uint8_t *)buf);
N
N        if (iap_status != 0) {
N            return ERROR_IAP_WRITE;
N        }
N
N        status = critical_erase_and_program(DAPLINK_ROM_UPDATE_START, sector_buf, DAPLINK_SECTOR_SIZE);
X        status = critical_erase_and_program(0x00000000, sector_buf, 0x00000400);
N
N        if (ERROR_SUCCESS == status) {
N            status = ERROR_SUCCESS;
N        }
N
N        // The bootloader has been updated so recompute the crc
N        info_crc_compute();
N        update_complete = true;
X        update_complete = 1;
N        return status;
N    }
N
N    return ERROR_IAP_NO_INTERCEPT;
N}
N
Nstatic error_t intercept_sector_erase(uint32_t addr)
N{
N    error_t status;
N    uint32_t updt_start = DAPLINK_ROM_UPDATE_START;
X    uint32_t updt_start = 0x00000000;
N    uint32_t updt_end = DAPLINK_ROM_UPDATE_START + DAPLINK_ROM_UPDATE_SIZE;
X    uint32_t updt_end = 0x00000000 + 0x00007C00;
N
N    if (state != STATE_OPEN) {
N        util_assert(0);
X        _util_assert((0), "..\\..\\..\\source\\daplink\\drag-n-drop\\iap_flash_intf.c", 444);
N        return ERROR_INTERNAL;
N    }
N
N    if ((addr < updt_start) || (addr >= updt_end)) {
N        return ERROR_IAP_OUT_OF_BOUNDS;
N    }
N
N    if (!daplink_is_interface()) {
N        return ERROR_IAP_NO_INTERCEPT;
N    }
N
N    /* Everything below here is interface specific */
N
N    if (DAPLINK_ROM_UPDATE_START == addr) {
X    if (0x00000000 == addr) {
N        uint32_t addr = DAPLINK_ROM_UPDATE_START;
X        uint32_t addr = 0x00000000;
N        status = critical_erase_and_program(addr, (uint8_t *)DAPLINK_ROM_IF_START, DAPLINK_MIN_WRITE_SIZE);
X        status = critical_erase_and_program(addr, (uint8_t *)0x00008000, 0x00000100);
N
N        if (ERROR_SUCCESS == status) {
N            // Intercept was successful
N            status = ERROR_SUCCESS;
N        }
N
N        return status;
N    }
N
N    return ERROR_IAP_NO_INTERCEPT;
N}
N
Nstatic error_t critical_erase_and_program(uint32_t addr, const uint8_t *data, uint32_t size)
N{
N    uint32_t iap_status;
N
N    if (size < DAPLINK_MIN_WRITE_SIZE) {
X    if (size < 0x00000100) {
N        util_assert(0);
X        _util_assert((0), "..\\..\\..\\source\\daplink\\drag-n-drop\\iap_flash_intf.c", 478);
N        return ERROR_INTERNAL;
N    }
N
N    // CRITICAL SECTION BELOW HERE!
N    // If something goes wrong with either
N    // the erase or write then the device
N    // will no longer be bootable.
N    // Erase the first sector
N    iap_status = flash_erase_sector(addr);
N
N    if (iap_status != 0) {
N        return ERROR_ERASE_ALL;
N    }
N
N    // Program the interface's vector table
N    iap_status = flash_program_page(addr, size, (uint8_t *)data);
N
N    if (iap_status != 0) {
N        return ERROR_IAP_WRITE;
N    }
N
N    return ERROR_SUCCESS;
N}
