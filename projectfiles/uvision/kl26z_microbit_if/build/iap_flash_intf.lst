Nstatic error_t erase_sector(uint32_t addr)
N{
N    uint32_t iap_status;
N    error_t status;
N    uint32_t sector_size;
N
N    if (state != STATE_OPEN) {
N        util_assert(0);
X        _util_assert((0), "..\\..\\..\\source\\daplink\\drag-n-drop\\iap_flash_intf.c", 256);
N        return ERROR_INTERNAL;
N    }
N
N    // Address must be on a sector boundary
N    sector_size = erase_sector_size(addr);
N
N    if (addr % sector_size != 0) {
N        util_assert(0);
X        _util_assert((0), "..\\..\\..\\source\\daplink\\drag-n-drop\\iap_flash_intf.c", 264);
N        state = STATE_ERROR;
N        return ERROR_INTERNAL;
