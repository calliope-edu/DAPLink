N#define DAPLINK_ROM_CONFIG_ADMIN_SIZE   0x00000400
N
N#define DAPLINK_ROM_IF_START            0x00008000
N#define DAPLINK_ROM_IF_SIZE             0x00017C00
N
N#define DAPLINK_ROM_CONFIG_USER_START   0x0001FC00
N#define DAPLINK_ROM_CONFIG_USER_SIZE    0x00000400
N
N/* RAM sizes */
