N
N    if (status != ERROR_IAP_NO_INTERCEPT) {
N        // The operation has been intercepted so
N        // return the result
N        if (ERROR_SUCCESS != status) {
N            state = STATE_ERROR;
N        }
N
N        return status;
N    }
N
N    iap_status = flash_erase_sector(addr);
N
N    if (iap_status != 0) {
