N    /* VFS user errors */
N    ERROR_ERROR_DURING_TRANSFER,
N    ERROR_TRANSFER_TIMEOUT,
N    ERROR_FILE_BOUNDS,
N    ERROR_OOO_SECTOR,
N
N    /* Target flash errors */
