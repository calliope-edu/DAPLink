Nstatic error_t program_page(uint32_t addr, const uint8_t *buf, uint32_t size)
N{
N    uint32_t iap_status;
N    error_t status;
N    uint32_t min_prog_size;
N    uint32_t sector_size;
N    uint32_t updt_end = DAPLINK_ROM_UPDATE_START + DAPLINK_ROM_UPDATE_SIZE;
X    uint32_t updt_end = 0x00000000 + 0x00007C00;
N
N    if (state != STATE_OPEN) {
N        util_assert(0);
X        _util_assert((0), "..\\..\\..\\source\\daplink\\drag-n-drop\\iap_flash_intf.c", 163);
N        return ERROR_INTERNAL;
N    }
N
N    min_prog_size = program_page_min_size(addr);
N    sector_size = erase_sector_size(addr);
N
N    // Address must be on a write size boundary
N    if (addr % min_prog_size != 0) {
N        util_assert(0);
X        _util_assert((0), "..\\..\\..\\source\\daplink\\drag-n-drop\\iap_flash_intf.c", 172);
N        state = STATE_ERROR;
N        return ERROR_INTERNAL;
N    }
N
N    // Programming size must be a non-zero multiple of the minimum write size
N    if ((size < min_prog_size) || (size % min_prog_size != 0)) {
N        util_assert(0);
X        _util_assert((0), "..\\..\\..\\source\\daplink\\drag-n-drop\\iap_flash_intf.c", 179);
N        state = STATE_ERROR;
N        return ERROR_INTERNAL;
N    }
N
N    // Write must not cross a sector boundary
N    if ((addr % sector_size) + size > sector_size) {
N        util_assert(0);
X        _util_assert((0), "..\\..\\..\\source\\daplink\\drag-n-drop\\iap_flash_intf.c", 186);
N        state = STATE_ERROR;
N        return ERROR_INTERNAL;
N    }
N
N    // Write must be in an erased sector (current_sector is always erased if it is set)
N    if (!mass_erase_performed) {
N        if (!current_sector_set) {
N            util_assert(0);
X            _util_assert((0), "..\\..\\..\\source\\daplink\\drag-n-drop\\iap_flash_intf.c", 194);
N            state = STATE_ERROR;
N            return ERROR_INTERNAL;
N        }
N
N        if ((addr < current_sector) || (addr >= current_sector + current_sector_size)) {
N            util_assert(0);
X            _util_assert((0), "..\\..\\..\\source\\daplink\\drag-n-drop\\iap_flash_intf.c", 200);
N            state = STATE_ERROR;
N            return ERROR_INTERNAL;
N        }
N    }
N
N    // Address must be sequential - no gaps
N    if (current_page_set && (addr != current_page + current_page_write_size)) {
N        util_assert(0);
X        _util_assert((0), "..\\..\\..\\source\\daplink\\drag-n-drop\\iap_flash_intf.c", 208);
N        state = STATE_ERROR;
N        return ERROR_INTERNAL;
N    }
N
N    if (!page_program_allowed(addr, size)) {
N        state = STATE_ERROR;
N        return ERROR_IAP_WRITE;
N    }
N
N    current_page_set = true;
X    current_page_set = 1;
N    current_page = addr;
N    current_page_write_size = size;
N    status = intercept_page_write(addr, buf, size);
N
N    if (status != ERROR_IAP_NO_INTERCEPT) {
N        // The operation has been intercepted so
N        // return the result
N        if (ERROR_SUCCESS != status) {
N            state = STATE_ERROR;
N        }
N
N        return status;
N    }
N
N    iap_status = flash_program_page(addr, size, (uint8_t *)buf);
N
N    if (iap_status != 0) {
N        state = STATE_ERROR;
N        return ERROR_IAP_WRITE;
N    }
N
N    if (addr + size >= updt_end) {
N        // Something has been updated so recompute the crc
N        info_crc_compute();
N        update_complete = true;
X        update_complete = 1;
N    }
N
N    return ERROR_SUCCESS;
