Nstatic bool page_program_allowed(uint32_t addr, uint32_t size)
Xstatic _Bool page_program_allowed(uint32_t addr, uint32_t size)
N{
N    // Check if any data would overlap with the application region
N    if ((addr < DAPLINK_ROM_APP_START + DAPLINK_ROM_APP_SIZE) && (addr + size > DAPLINK_ROM_APP_START)) {
X    if ((addr < 0x00008000 + 0x00017C00) && (addr + size > 0x00008000)) {
N        return false;
X        return 0;
N    }
N
N    return true;
X    return 1;
N}
