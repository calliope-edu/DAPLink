X#if 0L
S
S#define DAPLINK_ROM_APP_START            DAPLINK_ROM_BL_START
S#define DAPLINK_ROM_APP_SIZE             DAPLINK_ROM_BL_SIZE
S#define DAPLINK_ROM_UPDATE_START         DAPLINK_ROM_IF_START
