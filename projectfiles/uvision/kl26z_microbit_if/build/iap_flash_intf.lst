N
N    // Address must be sequential - no gaps
N    if (current_sector_set && (addr != current_sector + current_sector_size)) {
N        util_assert(0);
X        _util_assert((0), "..\\..\\..\\source\\daplink\\drag-n-drop\\iap_flash_intf.c", 271);
N        state = STATE_ERROR;
N        return ERROR_INTERNAL;
N    }
N
N    if (!sector_erase_allowed(addr)) {
N        state = STATE_ERROR;
N        return ERROR_IAP_ERASE_SECTOR;
