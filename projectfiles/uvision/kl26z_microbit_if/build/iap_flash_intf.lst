N#define DAPLINK_RAM_APP_SIZE            0x00003F00
N
N#define DAPLINK_RAM_SHARED_START        0x20002F00
N#define DAPLINK_RAM_SHARED_SIZE         0x00000100
N
N/* Flash Programming Info */
N
N#define DAPLINK_SECTOR_SIZE             0x00000400
N#define DAPLINK_MIN_WRITE_SIZE          0x00000100
N
N/* Current build */
N
