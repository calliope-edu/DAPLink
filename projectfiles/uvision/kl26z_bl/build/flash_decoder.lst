N    } else if (daplink_is_interface()) {
N        if (FLASH_DECODER_TYPE_BOOTLOADER == type) {
N            if (addr_valid && (DAPLINK_ROM_BL_START != addr)) {
X            if (addr_valid && (0x00000000 != addr)) {
