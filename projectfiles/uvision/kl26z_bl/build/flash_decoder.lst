N            break;
N
N        case FLASH_DECODER_TYPE_TARGET:
N            end_addr = target_device.flash_end;
N            break;
N
N        default:
N            return false;
X            return 0;
N    }
N
N    if (addr + size >= end_addr) {
N        return true;
X        return 1;
N    } else {
N        return false;
X        return 0;
N    }
N}
