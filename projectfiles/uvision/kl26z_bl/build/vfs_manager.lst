L 32 "..\..\..\source\daplink\daplink_debug.h" 2
N
N#ifdef __cplusplus
Sextern "C" {
N#endif
N
N#ifndef MSC_DEBUG
N//#define MSC_DEBUG
N#endif
N
N#if defined (MSC_DEBUG)
X#if 0L
S
Sstatic const char error_msg[] = "\r\n<OVERFLOW>\r\n";
S
Sstatic inline uint32_t daplink_debug(uint8_t *buf, uint32_t size)
S{
S    uint32_t total_free;
S    uint32_t write_free;
S    uint32_t error_len = strlen(error_msg);
S    total_free = USBD_CDC_ACM_DataFree();
S
S    if (total_free < error_len) {
S        // No space
S        return 0;
S    }
S
S    // Size available for writing
S    write_free = total_free - error_len;
S    size = MIN(write_free, size);
S    USBD_CDC_ACM_DataSend(buf, size);
S
S    if (write_free == size) {
S        USBD_CDC_ACM_DataSend((uint8_t *)error_msg, error_len);
S    }
S
S    return size;
S}
S
Sstatic char daplink_debug_buf[128] = {0};
Sstatic inline uint32_t daplink_debug_print(const char *format, ...)
S{
S    uint32_t ret;
S    int32_t r = 0;
S    va_list arg;
S    ret = 1;
S    va_start(arg, format);
S    r = vsnprintf(daplink_debug_buf, sizeof(daplink_debug_buf), format, arg);
S
S    if (r >= sizeof(daplink_debug_buf)) {
S        r = snprintf(daplink_debug_buf, sizeof(daplink_debug_buf), "<Error - string length %i exceeds print buffer>\r\n", r);
S        ret = 0;
S    }
S
S    va_end(arg);
S    daplink_debug((uint8_t *)daplink_debug_buf, r);
S    return ret;
S}
S
N#else
N
Nstatic inline uint32_t daplink_debug_print(const char *format, ...)
N{
N    return 1;
N}
N
Nstatic inline uint32_t daplink_debug(uint8_t *data, uint32_t size)
N{
N    return 1;
N}
N
N#endif
N
N#define debug_msg(fmt, args...) daplink_debug_print(fmt, ## args);
N#define debug_data(buf, size) daplink_debug(buf, size);
N
N#ifdef __cplusplus
S}
N#endif
N
N#endif
