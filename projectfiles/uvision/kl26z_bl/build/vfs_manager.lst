Nvoid usbd_msc_read_sect(uint32_t sector, uint8_t *buf, uint32_t num_of_sectors)
N{
N    sync_assert_usb_thread();
N
N    // dont proceed if we're not ready
N    if (!USBD_MSC_MediaReady) {
N        return;
N    }
N
N    // indicate msc activity
N    main_blink_msc_led(MAIN_LED_FLASH);
N    vfs_read(sector, buf, num_of_sectors);
N}
N
Nvoid usbd_msc_write_sect(uint32_t sector, uint8_t *buf, uint32_t num_of_sectors)
N{
N    sync_assert_usb_thread();
N
N    if (!USBD_MSC_MediaReady) {
N        return;
N    }
N
N    // Restart the disconnect counter on every packet
N    // so the device does not detach in the middle of a
N    // transfer.
N    time_usb_idle = 0;
N
N    if (TRASNFER_FINISHED == file_transfer_state.transfer_state) {
N        return;
N    }
N
N    // indicate msc activity
N    main_blink_msc_led(MAIN_LED_FLASH);
N    vfs_write(sector, buf, num_of_sectors);
N    if (TRASNFER_FINISHED == file_transfer_state.transfer_state) {
N        return;
N    }
N
N    if (vfs_get_root_dir_active() == true)
X    if (vfs_get_root_dir_active() == 1)
N    {
N        file_data_handler(sector, buf, num_of_sectors);
N    }
N}
N
Nstatic void sync_init(void)
N{
N    sync_thread = os_tsk_self();
X    sync_thread = _os_tsk_self((U32)rt_tsk_self);
N    os_mut_init(&sync_mutex);
X    _os_mut_init((U32)rt_mut_init,&sync_mutex);
N}
N
Nstatic void sync_assert_usb_thread(void)
N{
N    util_assert(os_tsk_self() == sync_thread);
X    _util_assert((_os_tsk_self((U32)rt_tsk_self) == sync_thread), "(file)", 356);
N}
N
Nstatic void sync_lock(void)
N{
N    os_mut_wait(&sync_mutex, 0xFFFF);
X    _os_mut_wait((U32)rt_mut_wait,&sync_mutex,0xFFFF);
N}
N
Nstatic void sync_unlock(void)
N{
N    os_mut_release(&sync_mutex);
X    _os_mut_release((U32)rt_mut_release,&sync_mutex);
N}
N
Nstatic bool changing_state()
Xstatic _Bool changing_state()
N{
N    return vfs_state != vfs_state_next;
N}
N
Nstatic void build_filesystem()
N{
N    // Update anything that could have changed file system state
N    file_transfer_state = default_transfer_state;
N    vfs_user_build_filesystem();
N    vfs_set_file_change_callback(file_change_handler);
N    // Set mass storage parameters
N    USBD_MSC_MemorySize = vfs_get_total_size();
N    USBD_MSC_BlockSize  = VFS_SECTOR_SIZE;
X    USBD_MSC_BlockSize  = 512;
N    USBD_MSC_BlockGroup = 1;
N    USBD_MSC_BlockCount = USBD_MSC_MemorySize / USBD_MSC_BlockSize;
N    USBD_MSC_BlockBuf   = (uint8_t *)usb_buffer;
N}
N
N// Callback to handle changes to the root directory.  Should be used with vfs_set_file_change_callback
Nstatic void file_change_handler(const vfs_filename_t filename, vfs_file_change_t change, vfs_file_t file, vfs_file_t new_file_data)
N{
N    vfs_mngr_printf("vfs_manager file_change_handler(name=%*s, file=%p, change=%i)\r\n", 11, filename, file, change);
X    ;
N    vfs_user_file_change_handler(filename, change, file, new_file_data);
N    if (TRASNFER_FINISHED == file_transfer_state.transfer_state) {
N        // If the transfer is finished stop further processing
N        return;
N    }
N
N    if (VFS_FILE_CHANGED == change) {
N        if (file == file_transfer_state.file_to_program) {
N            stream_type_t stream;
N            uint32_t size = vfs_file_get_size(new_file_data);
N            vfs_sector_t sector = vfs_file_get_start_sector(new_file_data);
N            stream = stream_type_from_name(filename);
N            transfer_update_file_info(file, sector, size, stream);
N        }
N    }
N
N    if (VFS_FILE_CREATED == change) {
N        stream_type_t stream;
N
N        if (STREAM_TYPE_NONE != stream_type_from_name(filename)) {
N            // Check for a know file extension to detect the current file being
N            // transferred.  Ignore hidden files since MAC uses hidden files with
N            // the same extension to keep track of transfer info in some cases.
N            if (!(VFS_FILE_ATTR_HIDDEN & vfs_file_get_attr(new_file_data))) {
N                stream = stream_type_from_name(filename);
N                uint32_t size = vfs_file_get_size(new_file_data);
N                vfs_sector_t sector = vfs_file_get_start_sector(new_file_data);
N                transfer_update_file_info(file, sector, size, stream);
N            }
N        }
N    }
N
N    if (VFS_FILE_DELETED == change) {
N        if (file == file_transfer_state.file_to_program) {
N            // The file that was being transferred has been deleted
N            transfer_reset_file_info();
N        }
N    }
N}
N
N// Handler for file data arriving over USB.  This function is responsible
N// for detecting the start of a BIN/HEX file and performing programming
Nstatic void file_data_handler(uint32_t sector, const uint8_t *buf, uint32_t num_of_sectors)
N{
N    stream_type_t stream;
N    uint32_t size;
N
N    // this is the key for starting a file write - we dont care what file types are sent
N    //  just look for something unique (NVIC table, hex, srec, etc) until root dir is updated
N    if (!file_transfer_state.stream_started) {
N        // look for file types we can program
N        stream = stream_start_identify((uint8_t *)buf, VFS_SECTOR_SIZE * num_of_sectors);
X        stream = stream_start_identify((uint8_t *)buf, 512 * num_of_sectors);
N
N        if (STREAM_TYPE_NONE != stream) {
N            transfer_stream_open(stream, sector);
N        }
N    }
N
N    if (file_transfer_state.stream_started) {
N        // Ignore sectors coming before this file
N        if (sector < file_transfer_state.start_sector) {
N            return;
N        }
N
N        // sectors must be in order
N        if (sector != file_transfer_state.file_next_sector) {
N            vfs_mngr_printf("vfs_manager file_data_handler sector=%i\r\n", sector);
X            ;
N
N            if (sector < file_transfer_state.file_next_sector) {
N                vfs_mngr_printf("    sector out of order! lowest ooo = %i\r\n",
N                                file_transfer_state.last_ooo_sector);
X                ;
N
N                if (VFS_INVALID_SECTOR == file_transfer_state.last_ooo_sector) {
X                if (0xFFFFFFFF == file_transfer_state.last_ooo_sector) {
N                    file_transfer_state.last_ooo_sector = sector;
N                }
N
N                file_transfer_state.last_ooo_sector =
N                    MIN(file_transfer_state.last_ooo_sector, sector);
X                    ((file_transfer_state . last_ooo_sector) < (sector) ? (file_transfer_state . last_ooo_sector) : (sector));
N            } else {
N                vfs_mngr_printf("    sector not part of file transfer\r\n");
X                ;
N            }
N
N            vfs_mngr_printf("    discarding data - size transferred=0x%x, data=%x,%x,%x,%x,...\r\n",
N                            file_transfer_state.size_transferred, buf[0], buf[1], buf[2], buf[3]);
X            ;
N            return;
N        }
N
N        // This sector could be part of the file so record it
N        size = VFS_SECTOR_SIZE * num_of_sectors;
X        size = 512 * num_of_sectors;
N        file_transfer_state.size_transferred += size;
N        file_transfer_state.file_next_sector = sector + num_of_sectors;
N
N        // If stream processing is done then discard the data
N        if (file_transfer_state.stream_finished) {
N            vfs_mngr_printf("vfs_manager file_data_handler\r\n    sector=%i, size=%i\r\n", sector, size);
X            ;
N            vfs_mngr_printf("    discarding data - size transferred=0x%x, data=%x,%x,%x,%x,...\r\n",
N                            file_transfer_state.size_transferred, buf[0], buf[1], buf[2], buf[3]);
X            ;
N            transfer_update_state(ERROR_SUCCESS);
N            return;
N        }
N
N        transfer_stream_data(sector, buf, size);
N    }
N}
N
Nstatic bool ready_for_state_change(void)
Xstatic _Bool ready_for_state_change(void)
N{
N    uint32_t timeout_ms = INVALID_TIMEOUT_MS;
X    uint32_t timeout_ms = 0xFFFFFFFF;
N    util_assert(vfs_state != vfs_state_next);
X    _util_assert((vfs_state != vfs_state_next), "(file)", 500);
N
N    if (VFS_MNGR_STATE_CONNECTED == vfs_state) {
N        switch (file_transfer_state.transfer_state) {
N            case TRANSFER_NOT_STARTED:
N            case TRASNFER_FINISHED:
N                timeout_ms = DISCONNECT_DELAY_MS;
X                timeout_ms = 500;
N                break;
N
N            case TRANSFER_IN_PROGRESS:
N                timeout_ms = DISCONNECT_DELAY_TRANSFER_TIMEOUT_MS;
X                timeout_ms = 20000;
N                break;
N
N            case TRANSFER_CAN_BE_FINISHED:
N                timeout_ms = DISCONNECT_DELAY_TRANSFER_IDLE_MS;
X                timeout_ms = 500;
N                break;
N
N            default:
N                util_assert(0);
X                _util_assert((0), "(file)", 518);
N                timeout_ms = DISCONNECT_DELAY_MS;
X                timeout_ms = 500;
N                break;
N        }
N    } else if ((VFS_MNGR_STATE_DISCONNECTED == vfs_state) &&
N               (VFS_MNGR_STATE_CONNECTED == vfs_state_next)) {
N        timeout_ms = CONNECT_DELAY_MS;
X        timeout_ms = 0;
N    } else if ((VFS_MNGR_STATE_RECONNECTING == vfs_state) &&
N               (VFS_MNGR_STATE_CONNECTED == vfs_state_next)) {
N        timeout_ms = RECONNECT_DELAY_MS;
X        timeout_ms = 2500;
N    } else if ((VFS_MNGR_STATE_RECONNECTING == vfs_state) &&
N               (VFS_MNGR_STATE_DISCONNECTED == vfs_state_next)) {
N        timeout_ms = 0;
N    }
N
N    if (INVALID_TIMEOUT_MS == timeout_ms) {
X    if (0xFFFFFFFF == timeout_ms) {
N        util_assert(0);
X        _util_assert((0), "(file)", 534);
N        timeout_ms = 0;
N    }
N
N    return time_usb_idle > timeout_ms ? true : false;
X    return time_usb_idle > timeout_ms ? 1 : 0;
N}
N
N// Abort a remount if one is pending
Nvoid abort_remount(void)
N{
N    sync_lock();
N
N    // Only abort a remount if in the connected state and reconnecting is the next state
N    if ((VFS_MNGR_STATE_RECONNECTING == vfs_state_next) && (VFS_MNGR_STATE_CONNECTED == vfs_state)) {
N        vfs_state_next = VFS_MNGR_STATE_CONNECTED;
N    }
N
N    sync_unlock();
N}
N
N// Update the tranfer state with file information
Nstatic void transfer_update_file_info(vfs_file_t file, uint32_t start_sector, uint32_t size, stream_type_t stream)
N{
N    vfs_mngr_printf("vfs_manager transfer_update_file_info(file=%p, start_sector=%i, size=%i)\r\n", file, start_sector, size);
X    ;
N
N    if (TRASNFER_FINISHED == file_transfer_state.transfer_state) {
N        util_assert(0);
X        _util_assert((0), "(file)", 560);
N        return;
N    }
N
N    // Initialize the directory entry if it has not been set
N    if (VFS_FILE_INVALID == file_transfer_state.file_to_program) {
X    if (0 == file_transfer_state.file_to_program) {
N        file_transfer_state.file_to_program = file;
N
N        if (file != VFS_FILE_INVALID) {
X        if (file != 0) {
N            vfs_mngr_printf("    file_to_program=%p\r\n", file);
X            ;
N        }
N    }
N
N    // Initialize the starting sector if it has not been set
N    if (VFS_INVALID_SECTOR == file_transfer_state.file_start_sector) {
X    if (0xFFFFFFFF == file_transfer_state.file_start_sector) {
N        file_transfer_state.file_start_sector = start_sector;
N
N        if (start_sector != VFS_INVALID_SECTOR) {
X        if (start_sector != 0xFFFFFFFF) {
N            vfs_mngr_printf("    start_sector=%i\r\n", start_sector);
X            ;
N        }
N    }
N
N    // Initialize the stream if it has not been set
N    if (STREAM_TYPE_NONE == file_transfer_state.stream) {
N        file_transfer_state.stream = stream;
N
N        if (stream != STREAM_TYPE_NONE) {
N            vfs_mngr_printf("    stream=%i\r\n", stream);
X            ;
N        }
N    }
N
N    // Check - File size must either grow or be smaller than the size already transferred
N    if ((size < file_transfer_state.file_size) && (size < file_transfer_state.size_transferred) && (size > 0)) {
N        vfs_mngr_printf("    error: file size changed from %i to %i\r\n", file_transfer_state.file_size, size);
X        ;
N        transfer_update_state(ERROR_ERROR_DURING_TRANSFER);
N        return;
N    }
N
N    // Check - Starting sector must be the same  - this is optional for file info since it may not be present initially
N    if ((VFS_INVALID_SECTOR != start_sector) && (start_sector != file_transfer_state.file_start_sector)) {
X    if ((0xFFFFFFFF != start_sector) && (start_sector != file_transfer_state.file_start_sector)) {
N        vfs_mngr_printf("    error: starting sector changed from %i to %i\r\n", file_transfer_state.file_start_sector, start_sector);
X        ;
N        transfer_update_state(ERROR_ERROR_DURING_TRANSFER);
N        return;
N    }
N
N    // Check - stream must be the same
N    if (stream != file_transfer_state.stream) {
N        vfs_mngr_printf("    error: changed types during transfer from %i to %i\r\n", stream, file_transfer_state.stream);
X        ;
N        transfer_update_state(ERROR_ERROR_DURING_TRANSFER);
N        return;
N    }
N
N    // Update values - Size is the only value that can change
N    file_transfer_state.file_size = size;
N    vfs_mngr_printf("    updated size=%i\r\n", size);
X    ;
N
N    transfer_update_state(ERROR_SUCCESS);
N}
N
N// Reset the transfer information or error if transfer is already in progress
Nstatic void transfer_reset_file_info()
N{
N    vfs_mngr_printf("vfs_manager transfer_reset_file_info()\r\n");
X    ;
N    //check if the data started streaming; size can be updated on matching start sector and stream type
N    if(file_transfer_state.stream_started){
N        //file, start sector and size has to be updated
N        file_transfer_state.file_to_program = VFS_FILE_INVALID;
X        file_transfer_state.file_to_program = 0;
N        file_transfer_state.file_start_sector = VFS_INVALID_SECTOR;
X        file_transfer_state.file_start_sector = 0xFFFFFFFF;
N        file_transfer_state.file_size = 0;
N    }else{
N          file_transfer_state = default_transfer_state;
N          abort_remount();
N    }
N    
N}
N
N// Update the tranfer state with new information
Nstatic void transfer_stream_open(stream_type_t stream, uint32_t start_sector)
N{
N    error_t status;
N    util_assert(!file_transfer_state.stream_open);
X    _util_assert((!file_transfer_state . stream_open), "(file)", 640);
N    util_assert(start_sector != VFS_INVALID_SECTOR);
X    _util_assert((start_sector != 0xFFFFFFFF), "(file)", 641);
N    vfs_mngr_printf("vfs_manager transfer_update_stream_open(stream=%i, start_sector=%i)\r\n",
N                    stream, start_sector);
X    ;
N
N    // Initialize the starting sector if it has not been set
N    if (VFS_INVALID_SECTOR == file_transfer_state.start_sector) {
X    if (0xFFFFFFFF == file_transfer_state.start_sector) {
N        file_transfer_state.start_sector = start_sector;
N
N        if (start_sector != VFS_INVALID_SECTOR) {
X        if (start_sector != 0xFFFFFFFF) {
N            vfs_mngr_printf("    start_sector=%i\r\n", start_sector);
X            ;
N        }
N    }
N
N    // Initialize the stream if it has not been set
N    if (STREAM_TYPE_NONE == file_transfer_state.stream) {
N        file_transfer_state.stream = stream;
N
N        if (stream != STREAM_TYPE_NONE) {
N            vfs_mngr_printf("    stream=%i\r\n", stream);
X            ;
N        }
N    }
N
N    // Check - Starting sector must be the same
N    if (start_sector != file_transfer_state.start_sector) {
N        vfs_mngr_printf("    error: starting sector changed from %i to %i\r\n", file_transfer_state.start_sector, start_sector);
X        ;
N        transfer_update_state(ERROR_ERROR_DURING_TRANSFER);
N        return;
N    }
N
N    // Check - stream must be the same
N    if (stream != file_transfer_state.stream) {
N        vfs_mngr_printf("    error: changed types during tranfer from %i to %i\r\n", stream, file_transfer_state.stream);
X        ;
N        transfer_update_state(ERROR_ERROR_DURING_TRANSFER);
N        return;
N    }
N
N    // Open stream
N    status = stream_open(stream);
N    vfs_mngr_printf("    stream_open stream=%i ret %i\r\n", stream, status);
X    ;
N
N    if (ERROR_SUCCESS == status) {
N        file_transfer_state.file_next_sector = start_sector;
N        file_transfer_state.stream_open = true;
X        file_transfer_state.stream_open = 1;
N        file_transfer_state.stream_started = true;
X        file_transfer_state.stream_started = 1;
N    }
N
N    transfer_update_state(status);
N}
N
N// Update the tranfer state with new information
Nstatic void transfer_stream_data(uint32_t sector, const uint8_t *data, uint32_t size)
N{
N    error_t status;
N    vfs_mngr_printf("vfs_manager transfer_stream_data(sector=%i, size=%i)\r\n", sector, size);
X    ;
N    vfs_mngr_printf("    size processed=0x%x, data=%x,%x,%x,%x,...\r\n",
N                    file_transfer_state.size_processed, data[0], data[1], data[2], data[3]);
X    ;
N
N    if (file_transfer_state.stream_finished) {
N        util_assert(0);
X        _util_assert((0), "(file)", 699);
N        return;
N    }
N
N    util_assert(size % VFS_SECTOR_SIZE == 0);
X    _util_assert((size % 512 == 0), "(file)", 703);
N    util_assert(file_transfer_state.stream_open);
X    _util_assert((file_transfer_state . stream_open), "(file)", 704);
N    status = stream_write((uint8_t *)data, size);
N    vfs_mngr_printf("    stream_write ret=%i\r\n", status);
X    ;
N
N    if (ERROR_SUCCESS_DONE == status) {
N        // Override status so ERROR_SUCCESS_DONE
N        // does not get passed into transfer_update_state
N        status = stream_close();
N        vfs_mngr_printf("    stream_close ret=%i\r\n", status);
X        ;
N        file_transfer_state.stream_open = false;
X        file_transfer_state.stream_open = 0;
N        file_transfer_state.stream_finished = true;
X        file_transfer_state.stream_finished = 1;
N        file_transfer_state.stream_optional_finish = true;
X        file_transfer_state.stream_optional_finish = 1;
N    } else if (ERROR_SUCCESS_DONE_OR_CONTINUE == status) {
N        status = ERROR_SUCCESS;
N        file_transfer_state.stream_optional_finish = true;
X        file_transfer_state.stream_optional_finish = 1;
N    } else {
N        file_transfer_state.stream_optional_finish = false;
X        file_transfer_state.stream_optional_finish = 0;
N    }
N
N    file_transfer_state.size_processed += size;
N    transfer_update_state(status);
N}
N
N// Check if the current transfer is still in progress, done, or if an error has occurred
Nstatic void transfer_update_state(error_t status)
N{
N    bool transfer_timeout;
X    _Bool transfer_timeout;
N    bool transfer_started;
X    _Bool transfer_started;
N    bool transfer_can_be_finished;
X    _Bool transfer_can_be_finished;
N    bool transfer_must_be_finished;
X    _Bool transfer_must_be_finished;
N    bool out_of_order_sector;
X    _Bool out_of_order_sector;
N    error_t local_status = status;
N    util_assert((status != ERROR_SUCCESS_DONE) &&
N                (status != ERROR_SUCCESS_DONE_OR_CONTINUE));
X    _util_assert(((status != ERROR_SUCCESS_DONE) && (status != ERROR_SUCCESS_DONE_OR_CONTINUE)), "(file)", 736);
N
N    if (TRASNFER_FINISHED == file_transfer_state.transfer_state) {
N        util_assert(0);
X        _util_assert((0), "(file)", 740);
N        return;
N    }
N
N    // Update file info status.  The end of a file is never known for sure since
N    // what looks like a complete file could be part of a file getting flushed to disk.
N    // The criteria for an successful optional finish is
N    // 1. A file has been detected
N    // 2. The size of the file indicated in the root dir has been transferred
N    // 3. The file size is greater than zero
N    // 4. Matching start sector set by stream and vfs changes
N    file_transfer_state.file_info_optional_finish =
N        (file_transfer_state.file_to_program != VFS_FILE_INVALID) &&
X        (file_transfer_state.file_to_program != 0) &&
N        (file_transfer_state.size_transferred >= file_transfer_state.file_size) &&
N        (file_transfer_state.file_size > 0) &&
N        (file_transfer_state.start_sector == file_transfer_state.file_start_sector);
N    transfer_timeout = file_transfer_state.transfer_timeout;
N    transfer_started = (VFS_FILE_INVALID != file_transfer_state.file_to_program) ||
X    transfer_started = (0 != file_transfer_state.file_to_program) ||
N                       (STREAM_TYPE_NONE != file_transfer_state.stream);
N    // The transfer can be finished if both file and stream processing
N    // can be considered complete
N    transfer_can_be_finished = file_transfer_state.file_info_optional_finish &&
N                               file_transfer_state.stream_optional_finish;
N    // The transfer must be fnished if stream processing is for sure complete
N    // and file processing can be considered complete
N    transfer_must_be_finished = file_transfer_state.stream_finished &&
N                                file_transfer_state.file_info_optional_finish;
N    out_of_order_sector = false;
X    out_of_order_sector = 0;
N
N    if (file_transfer_state.last_ooo_sector != VFS_INVALID_SECTOR) {
X    if (file_transfer_state.last_ooo_sector != 0xFFFFFFFF) {
N        util_assert(file_transfer_state.start_sector != VFS_INVALID_SECTOR);
X        _util_assert((file_transfer_state . start_sector != 0xFFFFFFFF), "(file)", 770);
N        uint32_t sector_offset = (file_transfer_state.last_ooo_sector -
N                                  file_transfer_state.start_sector) * VFS_SECTOR_SIZE;
X                                  file_transfer_state.start_sector) * 512;
N
N        if (sector_offset < file_transfer_state.size_processed) {
N            // The out of order sector was within the range of data already
N            // processed.
N            out_of_order_sector = true;
X            out_of_order_sector = 1;
N        }
N    }
N
N    // Set the transfer state and set the status if necessary
N    if (local_status != ERROR_SUCCESS) {
N        file_transfer_state.transfer_state = TRASNFER_FINISHED;
N    } else if (transfer_timeout) {
N        if (out_of_order_sector) {
N            local_status = ERROR_OOO_SECTOR;
N        } else if (!transfer_started) {
N            local_status = ERROR_SUCCESS;
N        } else if (transfer_can_be_finished) {
N            local_status = ERROR_SUCCESS;
N        } else {
N            local_status = ERROR_TRANSFER_TIMEOUT;
N        }
N
N        file_transfer_state.transfer_state = TRASNFER_FINISHED;
N    } else if (transfer_must_be_finished) {
N        file_transfer_state.transfer_state = TRASNFER_FINISHED;
N    } else if (transfer_can_be_finished) {
N        file_transfer_state.transfer_state = TRANSFER_CAN_BE_FINISHED;
N    } else if (transfer_started) {
N        file_transfer_state.transfer_state = TRANSFER_IN_PROGRESS;
N    }
N
N    if (TRASNFER_FINISHED == file_transfer_state.transfer_state) {
N        vfs_mngr_printf("vfs_manager transfer_update_state(status=%i)\r\n", status);
X        ;
N        vfs_mngr_printf("    file=%p, start_sect= %i %i, size=%i\r\n",
N                        file_transfer_state.file_to_program, file_transfer_state.start_sector,
N                        file_transfer_state.file_start_sector, file_transfer_state.file_size);
X        ;
N        vfs_mngr_printf("    stream=%i, size_processed=%i, opt_finish=%i, timeout=%i\r\n",
N                        file_transfer_state.stream, file_transfer_state.size_processed,
N                        file_transfer_state.file_info_optional_finish, transfer_timeout);
X        ;
N
N        // Close the file stream if it is open
N        if (file_transfer_state.stream_open) {
N            error_t close_status;
N            close_status = stream_close();
N            vfs_mngr_printf("    stream closed ret=%i\r\n", close_status);
X            ;
N            file_transfer_state.stream_open = false;
X            file_transfer_state.stream_open = 0;
N
N            if (ERROR_SUCCESS == local_status) {
N                local_status = close_status;
N            }
N        }
N
N        // Set the fail reason
N        fail_reason = local_status;
N        vfs_mngr_printf("    Transfer finished, status: %i=%s\r\n", fail_reason, error_get_string(fail_reason));
X        ;
N    }
N
N    // If this state change is not from aborting a transfer
N    // due to a remount then trigger a remount
N    if (!transfer_timeout) {
N        vfs_mngr_fs_remount();
N    }
N}
