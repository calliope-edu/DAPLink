Nvoid vfs_mngr_fs_enable(bool enable)
Xvoid vfs_mngr_fs_enable(_Bool enable)
N{
N    sync_lock();
N
N    if (enable) {
N        if (VFS_MNGR_STATE_DISCONNECTED == vfs_state_next) {
N            vfs_state_next = VFS_MNGR_STATE_CONNECTED;
N        }
N    } else {
N        vfs_state_next = VFS_MNGR_STATE_DISCONNECTED;
N    }
N
N    sync_unlock();
N}
N
Nvoid vfs_mngr_fs_remount(void)
N{
N    sync_lock();
N
N    // Only start a remount if in the connected state and not in a transition
N    if (!changing_state() && (VFS_MNGR_STATE_CONNECTED == vfs_state)) {
N        vfs_state_next = VFS_MNGR_STATE_RECONNECTING;
N    }
N
N    sync_unlock();
N}
N
Nvoid vfs_mngr_init(bool enable)
Xvoid vfs_mngr_init(_Bool enable)
N{
N    sync_assert_usb_thread();
N    build_filesystem();
N
N    if (enable) {
N        vfs_state = VFS_MNGR_STATE_CONNECTED;
N        vfs_state_next = VFS_MNGR_STATE_CONNECTED;
N        USBD_MSC_MediaReady = 1;
N    } else {
N        vfs_state = VFS_MNGR_STATE_DISCONNECTED;
N        vfs_state_next = VFS_MNGR_STATE_DISCONNECTED;
N        USBD_MSC_MediaReady = 0;
N    }
N}
N
Nvoid vfs_mngr_periodic(uint32_t elapsed_ms)
N{
N    bool change_state;
X    _Bool change_state;
N    vfs_mngr_state_t vfs_state_local;
N    vfs_mngr_state_t vfs_state_local_prev;
N    sync_assert_usb_thread();
N    sync_lock();
N
N    // Return immediately if the desired state has been reached
N    if (!changing_state()) {
N        sync_unlock();
N        return;
N    }
N
N    change_state = ready_for_state_change();
N
N    if (time_usb_idle < MAX_EVENT_TIME_MS) {
X    if (time_usb_idle < 60000) {
N        time_usb_idle += elapsed_ms;
N    }
N
N    if (!change_state) {
N        sync_unlock();
N        return;
N    }
N
N    vfs_mngr_printf("vfs_mngr_periodic()\r\n");
X    ;
N    vfs_mngr_printf("   time_usb_idle=%i\r\n", time_usb_idle);
X    ;
N    vfs_mngr_printf("   transfer_state=%i\r\n", file_transfer_state.transfer_state);
X    ;
N    // Transistion to new state
N    vfs_state_local_prev = vfs_state;
N    vfs_state = vfs_state_next;
N
N    switch (vfs_state) {
N        case VFS_MNGR_STATE_RECONNECTING:
N            // Transition back to the connected state
N            vfs_state_next = VFS_MNGR_STATE_CONNECTED;
N            break;
N
N        default:
N            // No state change logic required in other states
N            break;
N    }
N
N    vfs_state_local = vfs_state;
N    time_usb_idle = 0;
N    sync_unlock();
N    // Processing when leaving a state
N    vfs_mngr_printf("    state %i->%i\r\n", vfs_state_local_prev, vfs_state_local);
X    ;
N
N    switch (vfs_state_local_prev) {
N        case VFS_MNGR_STATE_DISCONNECTED:
N            // No action needed
N            break;
N
N        case VFS_MNGR_STATE_RECONNECTING:
N            // No action needed
N            break;
N
N        case VFS_MNGR_STATE_CONNECTED:
N
N            // Close ongoing transfer if there is one
N            if (file_transfer_state.transfer_state != TRASNFER_FINISHED) {
N                vfs_mngr_printf("    transfer timeout\r\n");
X                ;
N                file_transfer_state.transfer_timeout = true;
X                file_transfer_state.transfer_timeout = 1;
N                transfer_update_state(ERROR_SUCCESS);
N            }
N
N            util_assert(TRASNFER_FINISHED == file_transfer_state.transfer_state);
X            _util_assert((TRASNFER_FINISHED == file_transfer_state . transfer_state), "(file)", 264);
N            vfs_user_disconnecting();
N            break;
N    }
N
N    // Processing when entering a state
N    switch (vfs_state_local) {
N        case VFS_MNGR_STATE_DISCONNECTED:
N            USBD_MSC_MediaReady = 0;
N            break;
N
N        case VFS_MNGR_STATE_RECONNECTING:
N            USBD_MSC_MediaReady = 0;
N            break;
N
N        case VFS_MNGR_STATE_CONNECTED:
N            build_filesystem();
N            USBD_MSC_MediaReady = 1;
N            break;
N    }
N
N    return;
N}
N
