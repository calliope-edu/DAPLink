N/**
N *  @enum main_usb_busy_t
N *  @brief Defines the filtered activity of the USB connection
N */
Ntypedef enum {
N    MAIN_USB_IDLE,   /*!< MAIN_USB_IDLE value means no bus activity */
N    MAIN_USB_ACTIVE  /*!< MAIN_USB_ACTIVE value means MSC transfers are occuring */
N} main_usb_busy_t;
N
N/**
N *  @enum main_usb_connect_t
N *  @brief State the USB connection can be in
N */
Ntypedef enum {
N    MAIN_USB_DISCONNECTED,       /*!< MAIN_USB_DISCONNECTED state for a USB */
N    MAIN_USB_CONNECTING,         /*!< MAIN_USB_CONNECTING state for a USB */
N    MAIN_USB_CONNECTED,          /*!< MAIN_USB_CONNECTED state for a USB */
N    MAIN_USB_CHECK_CONNECTED,    /*!< MAIN_USB_CHECK_CONNECTED state for a USB */
N    MAIN_USB_DISCONNECTING       /*!< MAIN_USB_DISCONNECTING state for a USB */
N} main_usb_connect_t;
N
N/**
N *  @enum main_led_state_t
N *  @brief Statest the USB connection can be in
N */
Ntypedef enum {
N    MAIN_LED_DEF = 0,
N    MAIN_LED_FLASH,
N    MAIN_LED_FLASH_PERMANENT
N} main_led_state_t;
N
N/**
N *  Allows other parts of the program to request the device to eject physical media
N *  @param  none
N *  @return none
N */
Nvoid main_msc_disconnect_event(void);
N
N/**
N *  Delay the disconnect if there is one in progress
N *  @param  none
N *  @return none
N */
Nvoid main_msc_delay_disconnect_event(void);
N
N/**
N *  Allows other parts of the program to request the device to immediately eject physical media
N *  @param  none
N *  @return none
N */
Nvoid main_force_msc_disconnect_event(void);
N
N/**
N *  Allows other parts of the program to request a LED to toggle state
N *  @param  permanent decides if the led should remain on or flash
N *  @return none
N */
Nvoid main_blink_msc_led(main_led_state_t permanent);
N
N#ifdef __cplusplus
S}
N#endif
N
N#endif
