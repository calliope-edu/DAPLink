N   -- I2S Register Masks
N   ---------------------------------------------------------------------------- */
N
N/*!
N * @addtogroup I2S_Register_Masks I2S Register Masks
N * @{
N */
N
N/*! @name TCSR - SAI Transmit Control Register */
N#define I2S_TCSR_FWDE_MASK                       (0x2U)
N#define I2S_TCSR_FWDE_SHIFT                      (1U)
N#define I2S_TCSR_FWDE(x)                         (((uint32_t)(((uint32_t)(x)) << I2S_TCSR_FWDE_SHIFT)) & I2S_TCSR_FWDE_MASK)
N#define I2S_TCSR_FWIE_MASK                       (0x200U)
