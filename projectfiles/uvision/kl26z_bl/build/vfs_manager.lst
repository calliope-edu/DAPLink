Nvoid usbd_msc_init(void)
N{
N    sync_init();
N    build_filesystem();
N    vfs_state = VFS_MNGR_STATE_DISCONNECTED;
N    vfs_state_next = VFS_MNGR_STATE_DISCONNECTED;
N    time_usb_idle = 0;
N    USBD_MSC_MediaReady = 0;
N}
