L 26 "..\..\..\source\hic_hal\FlashOS.h" 2
N
N#ifdef __cplusplus
Sextern "C" {
N#endif
N
N#define VERS        1       // Interface Version 1.01
N#define NAME_MAX    128     // Max size of the routine name
N#define PAGE_MAX    65536   // Max Page Size for Programming
N#define SECTOR_NUM  512     // Max Number of Sector Items
N#define SECTOR_END  0xFFFFFFFF, 0xFFFFFFFF
N
N// FlashDevice.devType interface mechanism
N#define UNKNOWN     0
N#define ONCHIP      1
N#define EXT8BIT     2
N#define EXT16BIT    3
N#define EXT32BIT    4
N#define EXTSPI      5
N
N/**
N    @struct FlashSector
N    @brief  A structure to describe the size and start address of a flash sector
N */
Nstruct FlashSector {
N    uint32_t szSector;      /*!< Sector Size in Bytes */
N    uint32_t adrSector;     /*!< Address of Sector */
N};
N
N/**
N    @struct FlashDevice
N    @brief  A structure to describe particulars of a flash memory sub-system
N        and requirements of the driver
N */
Nstruct FlashDevice {
N    uint16_t vers;          /*!< Version Number and Architecture */
N    char devName[NAME_MAX]; /*!< Device Name and Description */
X    char devName[128];  
N    uint16_t devType;       /*!< Device Type: ONCHIP, EXT8BIT, EXT16BIT, ... */
N    uint32_t devAdr;        /*!< Default Device Start Address */
N    uint32_t szDev;         /*!< Total Size of Device */
N    uint32_t szPage;        /*!< Programming Page Size */
N    uint32_t res;           /*!< Reserved for future Extension */
N    uint8_t  valEmpty;      /*!< Content of Erased Memory */
N    uint32_t toProg;        /*!< Time Out of Program Page Function */
N    uint32_t toErase;       /*!< Time Out of Erase Sector Function */
N    struct FlashSector sectors[SECTOR_NUM]; /*!< Entries to describe flash memory layout */
X    struct FlashSector sectors[512];  
N};
N
N#ifdef __cplusplus
S}
N#endif
N
N#endif
L 23 "..\..\..\source\hic_hal\freescale\iap\FlashDev.c" 2
N
N#define FLASH_DRV_VERS (0x0100+VERS)   // Driver Version, do not modify!
N#define DEVICE_NAME    "MKXX"
N
Nstruct FlashDevice const FlashDevice = {
N    FLASH_DRV_VERS,             // Driver Version, do not modify!
X    (0x0100+1),             
N    DEVICE_NAME,                // Device Name
X    "MKXX",                
N    ONCHIP,                     // Device Type
X    1,                     
N    0x00000000,                 // Device Start Address
N    0x00000000,                 // Device Size
N    1024,                       // Programming Page Size
N    0,                          // Reserved, must be 0
N    0xFF,                       // Initial Content of Erased Memory
N    100,                        // Program Page Timeout 100 mSec
N    3000,                       // Erase Sector Timeout 3000 mSec
N    {{0x000400, 0x000000},      // Sector Size  1kB
N    {SECTOR_END}}
X    {0xFFFFFFFF, 0xFFFFFFFF}}
N};
