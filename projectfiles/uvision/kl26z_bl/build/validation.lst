L 25 "..\..\..\source\daplink\validation.c" 2
N
Nstatic inline uint32_t test_range(const uint32_t test, const uint32_t min, const uint32_t max)
N{
N    return ((test < min) || (test > max)) ? 0 : 1;
N}
N
N__weak uint8_t validate_bin_nvic(const uint8_t *buf)
N{
N    // test for known required NVIC entries
N    //  00 is stack pointer (RAM address)
N    //  04 is Reset vector  (FLASH address)
N    //  08 NMI_Handler      (FLASH address)
N    //  12 HardFault_Handler(FLASH address)
N    uint32_t i = 4, nvic_val = 0;
N    uint8_t index = 0, in_range = 0;
N    // test the initial SP value
N    memcpy(&nvic_val, buf + 0, sizeof(nvic_val));
N
N    if (0 == test_range(nvic_val, target_device.ram_start, target_device.ram_end)) {
N        while (!(target_device.extra_ram[index].start == 0 && target_device.extra_ram[index].end == 0)) { //try additional reqions if present
N            if (1 == test_range(nvic_val, target_device.extra_ram[index].start, target_device.extra_ram[index].end)) {
N                in_range = 1;
N                break;
N            }
N            index++;
N        }
N        if (in_range == 0) {
N            return 0;
N        }
N    }
N    
N    
N
N    // Reset_Handler
N    // NMI_Handler
N    // HardFault_Handler
N    for (; i <= 12; i += 4) {
N        memcpy(&nvic_val, buf + i, sizeof(nvic_val));
N        if (0 == test_range(nvic_val, target_device.flash_start, target_device.flash_end)) {
N            index = 0, in_range = 0;
N            while (!(target_device.extra_flash[index].start == 0 && target_device.extra_flash[index].end == 0)) { //try additional reqions if present
N                if (1 == test_range(nvic_val, target_device.extra_flash[index].start, target_device.extra_flash[index].end)) {
N                    in_range = 1;
N                    break;
N                }
N                index++;
N            }
N            if (in_range == 0) {
N                return 0;
N            }
N        }
N    }
N
N    return 1;
N}
N
N__weak uint8_t validate_hexfile(const uint8_t *buf)
N{
N    // look here for known hex records
N    // add hex identifier b[0] == ':' && b[8] == {'0', '2', '3', '4', '5'}
N    return ((buf[0] == ':') && ((buf[8] == '0') || (buf[8] == '2') || (buf[8] == '3') || (buf[8] == '4') || (buf[8] == '5'))) ? 1 : 0;
N}
