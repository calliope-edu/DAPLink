N/**
N @struct target_cfg_t
N @brief  The firmware configuration struct has unique about the chip its running on.
N */
Ntypedef struct target_cfg {
N    uint32_t sector_size;           /*!< Number of bytes in a sector used by flash erase and filesystem */
N    uint32_t sector_cnt;            /*!< Number of sectors a device has */
N    uint32_t flash_start;           /*!< Address of the application entry point */
N    uint32_t flash_end;             /*!< Address where the flash ends */
N    uint32_t ram_start;             /*!< Lowest contigous RAM address the application uses */
N    uint32_t ram_end;               /*!< Highest contigous RAM address the application uses */
N    program_target_t *flash_algo;   /*!< A pointer to the flash algorithm structure */
N    uint8_t erase_reset;            /*!< Reset after performing an erase */
N    const sector_info_t* sectors_info; 
N    int sector_info_length;
N    region_info_t extra_flash[MAX_EXTRA_FLASH_REGION + 1]; //!< Extra flash regions.
X    region_info_t extra_flash[3 + 1]; 
N    region_info_t extra_ram[MAX_EXTRA_RAM_REGION + 1]; //!< Extra RAM regions.
X    region_info_t extra_ram[3 + 1]; 
N} target_cfg_t;
